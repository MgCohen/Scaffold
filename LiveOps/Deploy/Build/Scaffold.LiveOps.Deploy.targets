<Project>
  <!--
    Auto-discover feature and game ProjectReferences from the on-disk LiveOps/ tree.
    Mirrors liveops.manifest.json featureGlobs/excludeGlobs so the deploy build always
    matches what is actually installed (no hand-edit required when packages are
    added/removed or when LiveOps/Game/* modules are authored).
  -->
  <ItemGroup>
    <ProjectReference Include="$(LiveOpsRoot)Scaffold\**\*.csproj"
                      Exclude="$(LiveOpsRoot)**\*.Tests.csproj" />
    <ProjectReference Include="$(LiveOpsRoot)Game\**\*.csproj"
                      Exclude="$(LiveOpsRoot)**\*.Tests.csproj" />
  </ItemGroup>
</Project>
