# Copy this file to `.env` in the same folder and fill in your values.
# `.env` is gitignored and will never be committed.

# --- Required ----------------------------------------------------------------

# Your Honeycomb ingest API key.
# Get one at https://ui.honeycomb.io/account (after signup).
# It looks like: hcaik_01abc234defg... (newer keys) or a 32-char hex string (legacy).
HONEYCOMB_API_KEY=replace-me

# --- Optional ----------------------------------------------------------------

# Honeycomb OTLP endpoint. The default works for the US region.
# For the EU region use https://api.eu1.honeycomb.io
HONEYCOMB_ENDPOINT=https://api.honeycomb.io

# The "service name" your data appears under in Honeycomb.
# Useful if you run telemetry from multiple machines or projects.
OTEL_SERVICE_NAME=claude-code

# How often metrics are flushed to Honeycomb, in milliseconds.
# 10000 (10s) is good for interactive use; default is 60000 (60s).
OTEL_METRIC_EXPORT_INTERVAL=10000

# Set to 1 to log tool detail attributes (bash commands, file paths, etc.).
# Useful for analysis, but means command lines and paths leave your machine.
LOG_TOOL_DETAILS=0

# Set to 1 to log your prompt text. Strongly NOT recommended unless you have
# a reason - your prompts will be visible in Honeycomb.
LOG_USER_PROMPTS=0
