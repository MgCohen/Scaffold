# Copy to .agents/local.env (gitignored) and adjust for your machine.
# Bash/zsh:  set -a; source .agents/local.env; set +a
# PowerShell: Get-Content .agents/local.env | ForEach-Object { if ($_ -match '^\s*([^#=]+)=(.*)$') { Set-Item -Path "env:$($matches[1])" -Value $matches[2].Trim('"') } }

# Windows (example):
# UNITY_PATH=C:\Program Files\Unity\Hub\Editor\6000.0.1f1\Editor\Unity.exe

# macOS (example):
# UNITY_PATH=/Applications/Unity/Hub/Editor/6000.0.1f1/Unity.app/Contents/MacOS/Unity

# Optional: allow Hub "newest install" fallback during strict compilation check
# SCAFFOLD_UNITY_ALLOW_VERSION_FALLBACK=1
